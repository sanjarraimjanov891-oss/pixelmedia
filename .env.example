# Gemini API key used by the server (keep secret, do not expose to the client)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Port for the Express server (Railway sets PORT automatically)
PORT=3001

# SQLite file path (optional; default is ./data/app.db)
DB_PATH="./data/app.db"

# Optional local default
NODE_ENV=development
