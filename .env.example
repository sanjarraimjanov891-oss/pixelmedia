# Gemini API key used by the server (keep secret, do not expose to the client)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Port for the Express server (Railway sets PORT automatically)
PORT=3001

# PostgreSQL URL (Railway). If set, server uses Postgres instead of SQLite.
# Example: postgresql://postgres:password@postgres.railway.internal:5432/railway
DATABASE_URL=

# SQLite file path (optional; default is ./data/app.db)
# Used only when DATABASE_URL is not set.
DB_PATH="./data/app.db"

# Optional local default
NODE_ENV=development
